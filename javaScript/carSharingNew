<!doctype html>
<html lang="de">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Car Sharing Stationen</title>
    <style>
      table { width: 100%; border-collapse: collapse; margin-top: 20px; }
      th, td { border: 1px solid #ddd; padding: 8px; text-align: left; }
      th { background-color: #f4f4f4; }
      tr:nth-child(even) { background-color: #f9f9f9; }
    </style>
  </head>
  <body>
    <h1>Car Sharing Stationen</h1>

    <table id="stationTable">
      <thead>
        <tr>
          <th>Name</th>
          <th>Aktiv</th>
          <th>Verfügbar</th>
          <th>Koordinate X (Lon)</th>
          <th>Koordinate Y (Lat)</th>
        </tr>
      </thead>
      <tbody id="tableBody">
        </tbody>
    </table>

    <script>
      async function fetchData() {
        try {
          const response = await fetch("https://mobility.api.opendatahub.com/v2/flat/CarsharingStation");
          const result = await response.json();
          
          // Die eigentlichen Stationen liegen im "data"-Array des Resultats
          const stations = result.data;
          
          displayData(stations);
        } catch (error) {
          console.error("Fehler beim Laden der Daten:", error);
          document.body.innerHTML += "<p style='color:red'>Fehler beim Laden der Daten.</p>";
        }
      }

      function displayData(stations) {
        const tableBody = document.getElementById("tableBody");
        
        stations.forEach(station => {
          // Eine neue Zeile erstellen
          const row = document.createElement("tr");

          // Die Zellen mit den entsprechenden Feldern befüllen
          // Hinweis: station.scoordinates enthält oft die Geometrie
          row.innerHTML = `
            <td>${station.sname || 'Unbekannt'}</td>
            <td>${station.sactive ? "Ja" : "Nein"}</td>
            <td>${station.savailable ? "Ja" : "Nein"}</td>
            <td>${station.scoordinate.x}</td>
            <td>${station.scoordinate.y}</td>
          `;

          tableBody.appendChild(row);
        });
      }

      // Startet den Vorgang
      fetchData();
    </script>
  </body>
</html>
